include=~/.config/mako/colors

font=JetBrainsMono Nerd Font Propo 12
width=420
outer-margin=20
padding=10,15
border-size=2
max-icon-size=32
default-timeout=5000
anchor=top-right
layer=overlay
max-visible=5
icons=1
icon-location=left
markup=1
format=<b>%s</b>\n%b
text-alignment=left
group-by=app-name,summary,body

[app-name=Spotify]
invisible=1

[mode=do-not-disturb]
invisible=true

[urgency=low]
default-timeout=2000

[urgency=critical]
default-timeout=0
layer=overlay
