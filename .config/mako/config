include=~/.config/mako/colors

font=JetBrainsMono Nerd Font Propo 12
width=380
height=200
margin=10
padding=10
border-size=0
border-radius=0
default-timeout=4000
anchor=top-right
layer=overlay
max-visible=5
icons=1
max-icon-size=48
icon-location=left
markup=1
format=<b>%s</b>\n%b
