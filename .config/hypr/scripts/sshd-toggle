#!/usr/bin/env bash

case "${1:-}" in
  watch)
    if systemctl is-active --quiet sshd 2>/dev/null; then
      echo '{"text": "SSH", "class": "active", "tooltip": "SSH service: active"}'
    else
      echo '{"text": "<s>SSH</s>", "class": "", "tooltip": "SSH service: inactive"}'
    fi
    ;;
  toggle)
    if systemctl is-active --quiet sshd 2>/dev/null; then
      sudo systemctl disable --now sshd
      notify-send "SSH" "Service stopped & disabled"
    else
      sudo systemctl enable --now sshd
      notify-send "SSH" "Service started & enabled"
    fi
    pkill -RTMIN+3 waybar
    ;;
esac
