#!/usr/bin/env bash

state_file="/tmp/caffeine-mode"

case "${1:-}" in
  watch)
    if [[ -f "$state_file" ]]; then
      echo '{"text": "", "class": "active", "tooltip": "Caffeine mode: on"}'
    else
      echo '{"text": "", "class": "", "tooltip": "Caffeine mode: off"}'
    fi
    ;;
  toggle)
    if [[ -f "$state_file" ]]; then
      rm -f "$state_file"
      systemctl --user start hypridle 2>/dev/null
      pkill -RTMIN+2 waybar
      notify-send "Caffeine" "Mode disabled"
    else
      touch "$state_file"
      systemctl --user stop hypridle 2>/dev/null
      pkill -RTMIN+2 waybar
      notify-send "Caffeine" "Mode enabled – system will not sleep"
    fi
    ;;
esac
