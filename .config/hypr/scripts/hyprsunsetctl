#!/bin/bash

ON_TEMP=4000
OFF_TEMP=6000

ensure_running() {
  if ! pgrep -x hyprsunset > /dev/null; then
    hyprsunset &
    sleep 0.5
  fi
}

get_temp() {
  hyprctl hyprsunset temperature 2>/dev/null | grep -oE '[0-9]+' || echo "$OFF_TEMP"
}

toggle() {
  ensure_running
  CURRENT=$(get_temp)
  if [ "$CURRENT" = "$OFF_TEMP" ]; then
    hyprctl hyprsunset temperature "$ON_TEMP"
  else
    hyprctl hyprsunset temperature "$OFF_TEMP"
  fi
}

status() {
  ensure_running
  CURRENT=$(get_temp)
  if [ "$CURRENT" = "$OFF_TEMP" ]; then
    echo '{"text":"","class":"off","tooltip":"Daylight (6000K)"}'
  else
    echo "{\"text\":\" ${CURRENT}K\",\"class\":\"on\",\"tooltip\":\"Nightlight (${CURRENT}K)\"}"
  fi
}

case "${1:-status}" in
  toggle) toggle ;;
  status) status ;;
  watch) while true; do status; sleep 0.5; done ;;
esac
